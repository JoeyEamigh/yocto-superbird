# The launcher script (/usr/bin/bridgething-chromium-launch) sources
# this file before exec'ing chromium. Restart the service to apply:
#   systemctl restart bridgething-chromium-kiosk
#
# BRIDGETHING_KIOSK_URL=http://127.0.0.1:8891/
# BRIDGETHING_KIOSK_EXTRA=--enable-logging=stderr --v=1
