#!/bin/sh
# bridgething-chromium-launch - exec chromium under weston as a kiosk.
#
# Sourced env file at /etc/default/bridgething-kiosk lets sysadmins
# (or, more commonly, this dev) override BRIDGETHING_KIOSK_URL and
# BRIDGETHING_KIOSK_EXTRA without rebuilding the image. Default URL is
# the bridgething daemon's modern HTTP/WS listen on port 8891.
#
# CDP is unconditionally on at 9223. chromium ≥ M111 silently ignores
# --remote-debugging-address=<non-localhost> (Google removed the bind-
# elsewhere path for security), so the listener is always 127.0.0.1.
# The host-side `bridgething-cdp` helper opens an SSH port-forward to
# pull 9223 to the dev host. We bind 9223 (not chromium's traditional
# 9222) because chromium hardcodes its bind port into every
# webSocketDebuggerUrl it announces in /json/version + /json/list:
# the tunnel must use the SAME port number on the host so that when
# chrome://inspect on the dev host parses those URLs and tries to
# open a DevTools session, the ws://127.0.0.1:9223/... target lands
# back through the tunnel onto the device. With matching ports the
# announced URL is reachable from the dev host as-is. As a side
# benefit, this avoids colliding with a desktop chromium that
# typically owns 9222 itself.
#
# --remote-allow-origins=* is required because chromium rejects
# DevTools WS upgrades from non-localhost origins by default
# (chrome://inspect, devtools://devtools, and any IDE that initiates
# from a non-localhost Origin all hit a 403). The Origin header is
# set by the *initiating page*, not the TCP destination, so the
# tunnel does NOT make the origin check pass on its own.
#
# --use-angle=gles overrides the chromium /usr/bin/chromium wrapper's
# default --use-angle=gles-egl. The wrapper's value is INVALID - chromium
# 147 only accepts (default|gles|vulkan|swiftshader). With gles-egl
# silently rejected, chromium falls back to gl=disabled and the GPU
# process exits at startup with "(gl=none,angle=none) not found in
# allowed implementations". With gles, ANGLE bridges to Mesa's libGLESv2
# → libgallium → Panfrost → Mali-G31. The chromium command line is
# last-wins for --use-angle, so this override after the wrapper's flags
# is what actually takes effect.
#
# --single-process collapses every utility process (network, storage,
# on-device-model, GPU) and the renderer into the browser process.
# Chromium docs warn this is "not recommended", but for a single-site
# kiosk running an in-house webapp the renderer-crash isolation it
# trades away is theatre - the renderer code path is mature, the JS
# is ours, and we only ever have one tab. The wins are concrete:
#   1. Eliminates the network-service-as-utility-process Mojo IPC
#      heartbeat. Under cold-boot pressure, that heartbeat would
#      time out and chromium would mark the in-flight navigation as
#      failed, leaving the tab parked on about:blank with no retry.
#      With network running in-process there is no IPC to time out.
#   2. ~70 MB saved from per-process libc/page-table duplication.
#      On 426 MB of RAM that is meaningful headroom.
#   3. No more --renderer-process-limit=1 / --process-per-site
#      complexity - those become no-ops under single-process.
#
# --num-raster-threads=4 lets the raster thread pool fill all four
# A53 cores. The chromium default for low-memory devices is 2.
#
# --enable-low-end-device-mode is INTENTIONALLY OMITTED. It would
# disable GPU rasterization (forcing CPU raster, slower) and put V8
# into lite-mode (interpreter, no JIT for many functions). On a stack
# with Panfrost working and ~150 MB available memory after the
# single-process savings, the perf hit dwarfs the memory savings.
#
# --js-flags is QUOTED. Without quotes, the shell word-splits the
# value and only the first inner flag reaches V8 - the prior version
# of this launcher passed --max-semi-space-size=4 unquoted, V8 never
# saw it, and the new generation ran at chromium's default size for
# years. Quote any future js-flags as one shell word.
#
# Niceness control lives in bridgething-chromium-kiosk.service via
# CapabilityBoundingSet=~CAP_SYS_NICE + LimitNICE=20. Chromium calls
# setpriority(-8) on its UI / IO / GPU threads internally; on 4x A53
# those at -8 preempt kswapd and the squashfs-percpu decompression
# workers - the very kernel work chromium needs to make progress on
# its own faults. The unit drops the cap so setpriority returns
# EPERM and the threads stay at nice=0.
#
# --user-data-dir lives on /var/cache (the data partition) so V8's
# Code Cache (parsed bytecode + JIT artifacts) and the HTTP disk
# cache survive reboots. With these on tmpfs (the previous default
# of /run/chromium-data), every boot was a cold cache for V8 + every
# webapp asset, and the first paint after boot was always the slow
# one. Persisting them turns first-paint-after-boot into roughly the
# speed of a warm-cache navigation. The data partition is shared
# between A/B slots so the cache survives OTA + bootslot swap; the
# directory itself is created on first boot by the unit's
# CacheDirectory= directive.
#
# --disk-cache-size=50 MiB caps the HTTP cache. Vite's webapp output
# uses content-hashed asset filenames so stale-cache-after-deploy is
# a non-issue: a new build produces new filenames, the old ones are
# unreferenced and get LRU-evicted.
#
# --enable-zero-copy switches GPU texture upload from the default
# "CPU-side staging buffer + memcpy into GPU memory" path to a
# direct DMA buffer the GPU reads in place. On Mali-G31 / Panfrost
# CPU and GPU share physical RAM, so the staging copy is pure waste.
# This saves one memcpy per uploaded raster tile and is one of the
# easier wins on shared-memory ARM SoCs.
#
# --password-store=basic skips chromium's dbus probe for a
# gnome-keyring / kwallet provider on startup. Neither exists on
# the kiosk image, so the lookup always fails and the only effect
# is a few ms of startup latency + spurious dbus traffic. `basic`
# (in-memory store) is the explicit no-op that bypasses the probe.
#
# --no-pings drops HTML hyperlink-auditing `<a ping>` requests.
# Useless for a single-site kiosk; non-zero CPU + network for
# nothing.
#
# --autoplay-policy=no-user-gesture-required permits HTMLMediaElement
# autoplay and Web Audio API audio context resume without a synthetic
# user gesture. The device has no audio output, but webapps doing
# visualizations through Web Audio API still need an unsuspended
# AudioContext - this lifts the M66+ default that requires a user
# tap before either is permitted.
#
# The --disable-features list trims chromium subsystems that don't
# apply to a 426 MB single-site offline kiosk:
#   Translate                      cloud-side language detection
#   BackForwardCache                no back/forward in a kiosk
#   GlobalMediaControls             no audio output
#   InterestFeedContentSuggestions  not a content surface
#   MediaRouter                     no Cast targets
#   MediaSessionService             no audio output
#   OptimizationHints               cloud-fetched perf hint blob
#   OptimizationGuideModelDownloading  on-device ML model downloads
#   DialMediaRouteProvider          SSDP Cast discovery
#   CalculateNativeWinOcclusion     Windows-only feature flag
#   AutofillServerCommunication     cloud autofill suggestions
# Each is feature-flag-gated rather than build-time-conditional, so
# disabling at launch is the only way to skip the init cost.

set -eu

BRIDGETHING_KIOSK_URL="${BRIDGETHING_KIOSK_URL:-http://127.0.0.1:8891/}"
BRIDGETHING_KIOSK_EXTRA="${BRIDGETHING_KIOSK_EXTRA:-}"

if [ -r /etc/default/bridgething-kiosk ]; then
    # shellcheck disable=SC1091
    . /etc/default/bridgething-kiosk
fi

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/weston}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"

exec /usr/bin/chromium \
    --kiosk \
    --no-first-run \
    --no-default-browser-check \
    --no-sandbox \
    --ozone-platform=wayland \
    --ozone-platform-hint=wayland \
    --use-angle=gles \
    --disk-cache-size=52428800 \
    --noerrdialogs \
    --disable-session-crashed-bubble \
    --disable-infobars \
    --check-for-update-interval=31536000 \
    --disable-pinch \
    --overscroll-history-navigation=0 \
    --force-color-profile=srgb \
    --single-process \
    --num-raster-threads=4 \
    --enable-zero-copy \
    --password-store=basic \
    --no-pings \
    --autoplay-policy=no-user-gesture-required \
    --js-flags="--max-old-space-size=192 --max-semi-space-size=16" \
    --disable-features=Translate,BackForwardCache,GlobalMediaControls,InterestFeedContentSuggestions,MediaRouter,MediaSessionService,OptimizationHints,OptimizationGuideModelDownloading,DialMediaRouteProvider,CalculateNativeWinOcclusion,AutofillServerCommunication \
    --disable-component-update \
    --disable-background-networking \
    --disable-sync \
    --disable-default-apps \
    --disable-extensions \
    --user-data-dir=/var/cache/bridgething/chromium \
    --proxy-server=socks5://127.0.0.1:1080 \
    --remote-debugging-port=9223 \
    --remote-allow-origins=* \
    ${BRIDGETHING_KIOSK_EXTRA} \
    "${BRIDGETHING_KIOSK_URL}"
