#!/bin/sh
# bridgething-chromium-launch - exec chromium under weston as a kiosk.
#
# Sourced env file at /etc/default/bridgething-kiosk lets sysadmins
# (or, more commonly, this dev) override BRIDGETHING_KIOSK_URL and
# BRIDGETHING_KIOSK_EXTRA without rebuilding the image. Default URL is
# the bridgething daemon's modern HTTP/WS listen on port 8891 - the
# daemon serves the active webapp at / and proxies on-demand assets via
# the /_gateway/ namespace.
#
# CDP is unconditionally on at 9223. chromium ≥ M111 silently ignores
# --remote-debugging-address=<non-localhost> (Google removed the bind-
# elsewhere path for security), so the listener is always 127.0.0.1.
# The host-side `bridgething-cdp` helper opens an SSH port-forward to
# pull 9223 to the dev host. We bind 9223 (not chromium's traditional
# 9222) because chromium hardcodes its bind port into every
# webSocketDebuggerUrl it announces in /json/version + /json/list:
# the tunnel must use the SAME port number on the host so that when
# chrome://inspect on the dev host parses those URLs and tries to
# open a DevTools session, the ws://127.0.0.1:9223/... target lands
# back through the tunnel onto the device. With matching ports the
# announced URL is reachable from the dev host as-is. As a side
# benefit, this avoids colliding with a desktop chromium that
# typically owns 9222 itself.
#
# --remote-allow-origins=* is required because chromium rejects
# DevTools WS upgrades from non-localhost origins by default
# (chrome://inspect, devtools://devtools, and any IDE that initiates
# from a non-localhost Origin all hit a 403). The Origin header is
# set by the *initiating page*, not the TCP destination, so the
# tunnel does NOT make the origin check pass on its own.
#
# --use-angle=gles overrides the chromium /usr/bin/chromium wrapper's
# default --use-angle=gles-egl. The wrapper's value is INVALID - chromium
# 147 only accepts (default|gles|vulkan|swiftshader). With gles-egl
# silently rejected, chromium falls back to gl=disabled and the GPU
# process exits at startup with "(gl=none,angle=none) not found in
# allowed implementations". With gles, ANGLE bridges to Mesa's libGLESv2
# → libgallium → Panfrost → Mali-G31. The chromium command line is
# last-wins for --use-angle, so this override after the wrapper's flags
# is what actually takes effect.

set -eu

BRIDGETHING_KIOSK_URL="${BRIDGETHING_KIOSK_URL:-http://127.0.0.1:8891/}"
BRIDGETHING_KIOSK_EXTRA="${BRIDGETHING_KIOSK_EXTRA:-}"

if [ -r /etc/default/bridgething-kiosk ]; then
    # shellcheck disable=SC1091
    . /etc/default/bridgething-kiosk
fi

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/weston}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"

exec /usr/bin/chromium \
    --kiosk \
    --no-first-run \
    --no-default-browser-check \
    --no-sandbox \
    --ozone-platform=wayland \
    --use-angle=gles \
    --disk-cache-size=1 \
    --media-cache-size=1 \
    --disable-application-cache \
    --noerrdialogs \
    --disable-session-crashed-bubble \
    --disable-infobars \
    --check-for-update-interval=31536000 \
    --disable-pinch \
    --overscroll-history-navigation=0 \
    --force-color-profile=srgb \
    --ozone-platform-hint=wayland \
    --enable-low-end-device-mode \
    --js-flags=--max-old-space-size=96 --max-semi-space-size=4 \
    --renderer-process-limit=1 \
    --process-per-site \
    --disable-features=Translate,BackForwardCache,GlobalMediaControls,InterestFeedContentSuggestions,MediaRouter \
    --disable-component-update \
    --disable-background-networking \
    --disable-sync \
    --disable-default-apps \
    --disable-extensions \
    --disable-features=AcceleratedVideoDecode \
    --user-data-dir=/run/chromium-data \
    --remote-debugging-port=9223 \
    --remote-allow-origins=* \
    ${BRIDGETHING_KIOSK_EXTRA} \
    "${BRIDGETHING_KIOSK_URL}"
