#!/bin/sh
# bridgething-chromium-launch - exec cast_shell under weston as a kiosk.
#
# The kiosk runs cast_shell, the Chromecast Receiver content embedder
# (chromium 147 chromecast/ build target). We ship cast_shell as
# /usr/lib/chromium/chromium-bin from the chromium-ozone-wayland
# recipe's cast-shell PACKAGECONFIG; the binary is materially smaller
# than chrome (~145 MB stripped vs ~273 MB), which is the fix for the
# squashfs page-fault storm under memory pressure that produced
# 9-second cold-of-kind animation latencies on this device.
#
# Sourced env file at /etc/default/bridgething-kiosk lets sysadmins
# (or, more commonly, this dev) override BRIDGETHING_KIOSK_URL and
# BRIDGETHING_KIOSK_EXTRA without rebuilding the image. Default URL
# is the bridgething daemon's modern HTTP/WS listen on port 8891.
#
# We cd into /usr/lib/chromium before exec so cast_shell's resource
# loader finds its paks (assets/cast_shell.pak, chromecast_locales/
# *.pak, icudtl.dat, snapshot_blob.bin) relative to cwd.
#
# CDP is unconditionally on at 9223. chromium >= M111 silently ignores
# --remote-debugging-address=<non-localhost> (Google removed the bind-
# elsewhere path for security), so the listener is always 127.0.0.1.
# The host-side `bridgething-cdp` helper opens an SSH port-forward to
# pull 9223 to the dev host. We bind 9223 (not chromium's traditional
# 9222) because chromium hardcodes its bind port into every
# webSocketDebuggerUrl it announces in /json/version + /json/list:
# the tunnel must use the SAME port number on the host so that when
# chrome://inspect on the dev host parses those URLs and tries to
# open a DevTools session, the ws://127.0.0.1:9223/... target lands
# back through the tunnel onto the device. As a side benefit, this
# avoids colliding with a desktop chromium that typically owns 9222
# itself. cast_shell's BUILD_ENG default UI-DevTools squat on 9223
# is gated off by patch 0003 in the chromium bbappend.
#
# --remote-allow-origins=* is required because chromium rejects
# DevTools WS upgrades from non-localhost origins by default
# (chrome://inspect, devtools://devtools, and any IDE that initiates
# from a non-localhost Origin all hit a 403). The Origin header is
# set by the *initiating page*, not the TCP destination, so the
# tunnel does NOT make the origin check pass on its own.
#
# --use-angle=gles routes through Mesa's libGLESv2 -> libgallium ->
# Panfrost -> Mali-G31. chromium 147 only accepts (default | gles |
# vulkan | swiftshader); the chromium-wrapper's gles-egl value from
# meta-chromium's kiosk-mode PACKAGECONFIG is INVALID and would
# silently fall back to gl=disabled. We exec cast_shell directly
# (no wrapper) so we control the flag set wholesale.
#
# --single-process collapses every utility process (network, storage,
# on-device-model, GPU) and the renderer into the browser process.
# Trade-offs (well-reasoned for this kiosk):
#   1. Eliminates the network-service-as-utility-process Mojo IPC
#      heartbeat that previously timed out under cold-boot pressure
#      and parked the tab on about:blank. (With cast_shell's smaller
#      binary memory pressure is gone, but single-process is still
#      simpler.)
#   2. ~70 MB saved from per-process libc/page-table duplication.
#   3. No --renderer-process-limit=1 / --process-per-site complexity.
# Renderer-crash isolation is theatre on a single-site kiosk; only
# one tab, code is ours.
#
# --num-raster-threads=4 lets the raster thread pool fill all four
# A53 cores.
#
# --js-flags is QUOTED. Without quotes, the shell word-splits the
# value and only the first inner flag reaches V8 - the prior version
# of this launcher passed --max-semi-space-size=4 unquoted, V8 never
# saw it, and the new generation ran at chromium's default size for
# years. Quote any future js-flags as one shell word.
#
# Niceness control lives in bridgething-chromium-kiosk.service via
# CapabilityBoundingSet=~CAP_SYS_NICE + LimitNICE=20. Chromium calls
# setpriority(-8) on its UI / IO / GPU threads internally; on 4x A53
# those at -8 preempt kswapd and any other kernel work in the
# critical path of the renderer's own page faults. Stripping
# CAP_SYS_NICE makes setpriority return EPERM and the threads stay
# at nice=0.
#
# --user-data-dir lives on /var/cache (the data partition) so V8's
# Code Cache (parsed bytecode + JIT artifacts) and the HTTP disk
# cache survive reboots. Persisting them turns first-paint-after-
# boot into roughly the speed of a warm-cache navigation. The data
# partition is shared between A/B slots so the cache survives OTA +
# bootslot swap; the directory itself is created on first boot by
# the unit's CacheDirectory= directive.
#
# --disk-cache-size=50 MiB caps the HTTP cache. Vite's webapp output
# uses content-hashed asset filenames so stale-cache-after-deploy
# is a non-issue: a new build produces new filenames, the old ones
# are unreferenced and get LRU-evicted.
#
# --enable-zero-copy switches GPU texture upload from the default
# "CPU-side staging buffer + memcpy into GPU memory" path to a
# direct DMA buffer the GPU reads in place. On Mali-G31 / Panfrost
# CPU and GPU share physical RAM, so the staging copy is pure waste.
#
# --autoplay-policy=no-user-gesture-required permits HTMLMediaElement
# autoplay and Web Audio API audio context resume without a synthetic
# user gesture. The device has no audio output but webapps using Web
# Audio API for visualizations still need an unsuspended
# AudioContext.
#
# Egress lockdown. The SOCKS proxy on 127.0.0.1:1080 tunnels webapp
# traffic over Bluetooth (RFCOMM) to the paired phone, so every byte
# chromium initiates on its own competes with the webapp for that
# pipe. cast_shell already excludes most of the chrome-specific
# warmup paths (Google services, variations seed, GAIA, etc.); the
# --disable-background-networking + --disable-component-update +
# --disable-features=SafeBrowsing,DnsOverHttps,FedCm,AcceptCHFrame,
# Reporting belt-and-suspenders kill any remaining background egress
# inherited from the chromium content/ tree.
#
# Loopback auto-bypass keeps the kiosk URL on 127.0.0.1:8891 working
# unconditionally regardless of any active webapp's net.proxy
# permission - the bridgething webserver is reached directly, never
# through the SOCKS path.
#
# --cast-graphics-width=800 --cast-graphics-height=480 seed the
# CastScreen primary display via CastDisplayConfigurator's existing
# command-line path (chromecast/browser/cast_display_configurator.cc
# kCastGraphicsWidth / kCastGraphicsHeight). Without these flags the
# configurator falls back to GetDefaultScreenResolution() = 1280x720,
# CastContentWindowAura sizes the cast_shell wl_surface to that, and
# the actual panel (800x480 after weston's mode=480x800 transform=
# rotate-270) shows the compositor background because the wl_surface
# extents don't match what weston is presenting. With the right
# resolution the host bounds line up with the wl_output and the
# webapp renders to the panel. cast_core normally drives this through
# its runtime display bring-up, gated off by patch 0001.
#
# GPU compositing is enabled (no --disable-gpu-compositing). The viz
# Display compositor's final composite-to-output step uses the
# SkiaRenderer / OverlayProcessorOzone / GbmSurfacelessWayland /
# WaylandBufferManagerHost chain through ANGLE-GLES on Mesa-Panfrost on
# the Mali-G31. Patches 0006-0009 in the chromium bbappend together
# remove the four Cast-hardware assumptions that prevented this chain
# from completing on bridgething (set_fullscreen instead of set_maxi
# mized, opaque-black compositor backstop, no kDisableGpuEarlyInit
# default, ShouldCreatePrimaryPlane returns true even though IS_CASTOS).
# The wedge in 0009 was found via differential perfetto trace
# (--trace-startup=wayland,viz,gpu) - in the wedged build the
# OverlayProcessorOzone gates the root render pass out of the candidate
# list and the ScheduleOverlayPlane chain never runs, so no wl_buffer
# is ever attached to the wl_surface. With all four patches GPU
# compositing works and the device returns the 0.5-1.4 A53 cores that
# software composite was eating per workload.
#
# --enable-input is mandatory for cast_shell to deliver hardware input.
# Without it, CastWindowTreeHostAura::DispatchEvent early-returns on
# every ui::Event and the root window gets a NullWindowTargeter, so
# wl_touch dispatches from ozone-wayland arrive at the host but are
# dropped before any aura window sees them. CDP Input.dispatch* keeps
# working because it injects downstream of aura, at the render widget
# host. Cast's intent for the default-off behaviour is engineering
# builds that boot to a non-interactive splash before a runtime app
# takes over; the bridgething kiosk has no such second stage. Pairs
# with chromium patch 0010 which flips enable_touch_input on the
# CastWebViewParams so the (now-delivered) touch events also clear
# the TouchBlocker pre-target handler in CastContentWindowAura.

set -eu

BRIDGETHING_KIOSK_URL="${BRIDGETHING_KIOSK_URL:-http://127.0.0.1:8891/}"
BRIDGETHING_KIOSK_EXTRA="${BRIDGETHING_KIOSK_EXTRA:-}"
BRIDGETHING_KIOSK_SINGLE_PROCESS="${BRIDGETHING_KIOSK_SINGLE_PROCESS:-1}"

# /etc/default/bridgething-kiosk is the image default (ro on squashfs
# / ext4 rootfs). /opt/bridgething/kiosk-env is the writable override
# on the settings-partition overlay (bind-mounted by the
# bridgething-opt-overlay service; survives bootslot swap + OTA). The
# override file is sourced last so it wins; absent file is fine.
if [ -r /etc/default/bridgething-kiosk ]; then
    # shellcheck disable=SC1091
    . /etc/default/bridgething-kiosk
fi
if [ -r /opt/bridgething/kiosk-env ]; then
    # shellcheck disable=SC1091
    . /opt/bridgething/kiosk-env
fi

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/weston}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"

# --single-process is the kiosk default; multi-process (zygote CoW for
# renderer + GPU + utility) is opt-in via /etc/default/bridgething-kiosk
# so the bench matrix can flip between cells with just a sed + service
# restart. Empty value when SINGLE_PROCESS=0; ${SINGLE_PROCESS_FLAG}
# expansion in the exec line then collapses to nothing.
if [ "${BRIDGETHING_KIOSK_SINGLE_PROCESS}" = "1" ]; then
    SINGLE_PROCESS_FLAG=--single-process
else
    SINGLE_PROCESS_FLAG=
fi

cd /usr/lib/chromium

# shellcheck disable=SC2086
exec ./chromium-bin \
    --no-first-run \
    --no-default-browser-check \
    --no-sandbox \
    --ozone-platform=wayland \
    --ozone-platform-hint=wayland \
    --use-angle=gles \
    --cast-graphics-width=800 \
    --cast-graphics-height=480 \
    --enable-input \
    --disk-cache-size=52428800 \
    --allow-insecure-localhost \
    --noerrdialogs \
    --disable-session-crashed-bubble \
    --disable-infobars \
    --check-for-update-interval=31536000 \
    --disable-pinch \
    --overscroll-history-navigation=0 \
    --force-color-profile=srgb \
    ${SINGLE_PROCESS_FLAG} \
    --num-raster-threads=4 \
    --enable-zero-copy \
    --password-store=basic \
    --no-pings \
    --autoplay-policy=no-user-gesture-required \
    --js-flags="--max-old-space-size=192 --max-semi-space-size=16 --no-lazy" \
    --disable-features=Translate,BackForwardCache,GlobalMediaControls,InterestFeedContentSuggestions,MediaRouter,MediaSessionService,OptimizationHints,OptimizationGuideModelDownloading,DialMediaRouteProvider,CalculateNativeWinOcclusion,AutofillServerCommunication,SafeBrowsing,NetworkTimeServiceQuerying,DnsOverHttps,FedCm,AcceptCHFrame,Reporting \
    --disable-component-update \
    --disable-background-networking \
    --user-data-dir=/var/cache/bridgething/chromium \
    --proxy-server=socks5://127.0.0.1:1080 \
    --remote-debugging-port=9223 \
    --remote-allow-origins=* \
    ${BRIDGETHING_KIOSK_EXTRA} \
    "${BRIDGETHING_KIOSK_URL}"
