# Bridgething prod OTA - A/B slot, delta system.img + raw boot.img.
#
# system.img is the rootfs image under whatever extension
# SUPERBIRD_ROOTFS_TYPE selected (ext4 on prod, squashfs-lz4 on
# dev). swupdate treats it as opaque bytes; the kernel detects the
# filesystem from the superblock magic at mount time.
#
# `system.img.zck.zckheader` is a tiny (~1% of the rootfs) zchunk
# index. The delta handler parses it, hashes the chunks of the
# `source` partition (the currently-mounted slot), figures out
# which chunks are missing, fetches them via HTTP from `url`,
# reassembles into a full image in /tmp, then hands the result to
# the chained `raw` handler which writes to the inactive slot's
# byte offset on /dev/mmcblk0.
#
# `boot.img` and `dtb` (raw board DTB written to dtbo_X) stay as
# raw types - at 16 MB and ~50 KB respectively, neither benefits
# from content-defined chunking, and the transfer cost is fine.
# u-boot loads the DTB from dtbo_X at fdt_addr (NOT from boot.img's
# second-stage), so a kernel update without a matching dtbo update
# would leave the new kernel parsing the old DTB.
#
# Selector: `swupdate -i .../prod.swu -e stable,slot_a` writes the
# slot A partitions (target=p1, source=p2); `... slot_b` writes
# slot B (target=p2, source=p1). bridgething-ab picks the inactive
# slot automatically.
#
# `installed-directly = true` is set on boot.img only - streaming
# the raw blob straight into the handler avoids the TMPDIR copy.
# The delta handler explicitly REJECTS streaming (it needs the
# whole zck header on disk before parsing), so system.img.zck.zckheader
# stages through TMPDIR. Header is ~500 KB so /tmp tmpfs is fine.
# After header parsing the delta handler streams chunks directly
# into the chain (raw) handler - the assembled 516 MB never
# touches TMPDIR.
#
# Slot flip via in-manifest bootenv block - swupdate flips
# active_slot atomically after all images write successfully.
# Required CONFIG_BOOTLOADERHANDLER=y in swupdate (see
# meta-bridgething's swupdate bbappend); without that flag the
# parser rejects bootenv sections with "bootloader support absent".
# bridgething-ab still owns want_boot=kernel + slot_X_try reset
# (boot policy, not OTA atomicity).

software =
{
    version = "@@VERSION@@";
    description = "Bridgething OTA";

    # Matched against /etc/hwrevision on the device. The format
    # there is `<board> <rev>`; sw-description's
    # `hardware-compatibility` list matches the second column.
    hardware-compatibility: [ "1.0" ];

    stable: {
        slot_a: {
            images: (
                {
                    filename = "boot.img";
                    type = "raw";
                    device = "/dev/mmcblk0";
                    offset = "@@BOOT_A_OFFSET@@";
                    installed-directly = true;
                },
                {
                    filename = "dtb";
                    type = "raw";
                    device = "/dev/mmcblk0";
                    offset = "@@DTBO_A_OFFSET@@";
                    installed-directly = true;
                },
                {
                    filename = "system.img.zck.zckheader";
                    type = "delta";
                    device = "/dev/mmcblk0";
                    offset = "@@SYSTEM_A_OFFSET@@";
                    properties: {
                        url = "@@DELTA_URL_BASE@@/system.img.zck";
                        source = "@@SLOT_A_SOURCE@@";
                        chain = "raw";
                    };
                }
            );
            bootenv: (
                { name = "active_slot"; value = "_a"; }
            );
        };
        slot_b: {
            images: (
                {
                    filename = "boot.img";
                    type = "raw";
                    device = "/dev/mmcblk0";
                    offset = "@@BOOT_B_OFFSET@@";
                    installed-directly = true;
                },
                {
                    filename = "dtb";
                    type = "raw";
                    device = "/dev/mmcblk0";
                    offset = "@@DTBO_B_OFFSET@@";
                    installed-directly = true;
                },
                {
                    filename = "system.img.zck.zckheader";
                    type = "delta";
                    device = "/dev/mmcblk0";
                    offset = "@@SYSTEM_B_OFFSET@@";
                    properties: {
                        url = "@@DELTA_URL_BASE@@/system.img.zck";
                        source = "@@SLOT_B_SOURCE@@";
                        chain = "raw";
                    };
                }
            );
            bootenv: (
                { name = "active_slot"; value = "_b"; }
            );
        };
    };
};
