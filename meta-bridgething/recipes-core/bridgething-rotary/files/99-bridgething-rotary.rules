# Hide the kernel rotary-encoder evdev node from libinput. The
# bridgething-rotary daemon grabs it directly (EVIOCGRAB) and re-emits
# scroll events through a uinput virtual mouse, which libinput then
# sees as a proper pointer.
#
# Without this rule, libinput opens the rotary, fails to classify it
# as a pointer (no buttons + only REL_HWHEEL), and produces a degenerate
# pointer device that flashes the cursor on rotation but generates no
# scroll. Worse, libinput holds the device open for the seat session
# lifetime, so the daemon's EVIOCGRAB races libinput at startup.
SUBSYSTEM=="input", KERNEL=="event*", ATTRS{name}=="rotary*", ENV{LIBINPUT_IGNORE_DEVICE}="1"
