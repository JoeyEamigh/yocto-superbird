#!/bin/sh
# /usr/bin/bridgething: pick the right daemon binary for this boot.
#
# Lookup order:
#   1. /opt/bridgething/daemon/bridgething.current  (overlay; current)
#   2. /usr/libexec/bridgething                     (squashfs; fallback)
#
# The .current path is the daemon hot-swap path: companion-pushed binary
# updates land here via atomic rename, and dev iteration via push-daemon
# uses the same path. The fallback is the binary baked into squashfs at
# image build time. If the overlay is unavailable (bind-mount failed,
# binary missing, mount-point empty after factory wipe), the launcher
# silently falls through to the squashfs binary so the device still boots
# to a working daemon.
CURRENT=/opt/bridgething/daemon/bridgething.current
FALLBACK=/usr/libexec/bridgething

if [ -x "$CURRENT" ]; then
    exec "$CURRENT" "$@"
fi

exec "$FALLBACK" "$@"
