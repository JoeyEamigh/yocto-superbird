#!/bin/sh
# Bridgething rollback: react to a daemon that won't stay up.
#
# Triggered by bridgething.service's OnFailure= when StartLimitBurst is
# hit (3 failures in 60s). Rotates the broken binary aside, promotes the
# previous binary if available, and restarts the daemon. If there's no
# previous binary, removes .current entirely so the launcher falls
# through to the squashfs fallback at /usr/libexec/bridgething - the
# device stays usable, just on the older daemon shipped with the image.
#
# Crucially, this script must NOT itself escalate into another rollback.
# It does its work and exits; the unit is Type=oneshot with no OnFailure
# of its own. The reset-failed + start sequence at the end gives the
# daemon a fresh restart-counter window.
set -eu

DAEMON_DIR=/opt/bridgething/daemon
CURRENT="${DAEMON_DIR}/bridgething.current"
PREVIOUS="${DAEMON_DIR}/bridgething.previous"
TIMESTAMP=$(date -u +%Y%m%dT%H%M%SZ)
BROKEN="${DAEMON_DIR}/bridgething.broken.${TIMESTAMP}"

if [ ! -e "$CURRENT" ]; then
    echo "bridgething-rollback: ${CURRENT} missing; nothing to rotate"
elif [ -e "$PREVIOUS" ]; then
    mv "$CURRENT" "$BROKEN"
    mv "$PREVIOUS" "$CURRENT"
    echo "bridgething-rollback: promoted previous -> current; broken kept at ${BROKEN}"
else
    mv "$CURRENT" "$BROKEN"
    echo "bridgething-rollback: no previous to promote; falling through to squashfs fallback"
fi

# Trim broken backups: keep last 3 to bound disk usage on the settings
# partition (256 MB total, daemon ~17 MB each).
ls -1t "${DAEMON_DIR}"/bridgething.broken.* 2>/dev/null \
    | tail -n +4 \
    | xargs -r rm -f

systemctl reset-failed bridgething.service
systemctl start bridgething.service
