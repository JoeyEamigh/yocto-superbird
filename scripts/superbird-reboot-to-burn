#!/usr/bin/env bash
# set want_boot=burn via fw_setenv and reboot. round-trip back via superbird-boot-kernel.sh.

set -euo pipefail

HOST="${SUPERBIRD_HOST:-bridgething.local}"

exec ssh \
    -o UserKnownHostsFile=/dev/null \
    -o StrictHostKeyChecking=no \
    -o LogLevel=ERROR \
    "root@${HOST}" 'fw_setenv want_boot burn && echo "want_boot=burn set; rebooting..." && systemctl reboot'
