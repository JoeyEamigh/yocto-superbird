#!/usr/bin/env bash
# Explicitly drop the device into USB burn mode for the next boot.
#
# As of the consolidated-images build, env.txt defaults to
# want_boot=kernel and bridgething-boot-confirm no longer flips it
# back to burn after each kernel boot. Plain `systemctl reboot` from
# Linux now stays in the kernel branch. To enter burn mode (e.g. for
# `flashthing-cli` to write a fresh image), this helper sets
# want_boot=burn via libubootenv-bin's fw_setenv and then reboots.
#
# Round-trip back to kernel after a flash is the existing
# `superbird-boot-kernel.sh` (via burn-mode bulkcmd).

set -euo pipefail

HOST="${SUPERBIRD_HOST:-10.42.1.2}"

exec ssh \
    -o UserKnownHostsFile=/dev/null \
    -o StrictHostKeyChecking=no \
    -o LogLevel=ERROR \
    "root@${HOST}" 'fw_setenv want_boot burn && echo "want_boot=burn set; rebooting..." && systemctl reboot'
