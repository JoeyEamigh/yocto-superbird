#!/usr/bin/env bash
# ssh into the device over the usb gadget. SUPERBIRD_HOST overrides the mdns default.
set -euo pipefail

HOST=${SUPERBIRD_HOST:-bridgething.local}

exec ssh \
    -o AddressFamily=inet \
    -o UserKnownHostsFile=/dev/null \
    -o StrictHostKeyChecking=no \
    -o GlobalKnownHostsFile=/dev/null \
    -o ConnectTimeout=5 \
    -o LogLevel=ERROR \
    "root@$HOST" "$@"
