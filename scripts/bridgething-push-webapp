#!/usr/bin/env bash
# rsync a webapp bundle to /var/bridgething/webapps/<name>/. default name = basename of local path.

set -euo pipefail

if [ $# -lt 1 ]; then
    echo "usage: bridgething-push-webapp <local-path> [<remote-name>]" >&2
    exit 2
fi

LOCAL="$1"
NAME="${2:-$(basename "$LOCAL")}"

if [ ! -e "$LOCAL" ]; then
    echo "bridgething-push-webapp: local path does not exist: $LOCAL" >&2
    exit 1
fi

HOST="${SUPERBIRD_HOST:-bridgething.local}"
DEST="/var/bridgething/webapps/${NAME}"

exec rsync -avz --delete \
    -e "ssh -o UserKnownHostsFile=/dev/null -o StrictHostKeyChecking=no -o LogLevel=ERROR" \
    "${LOCAL%/}/" "root@${HOST}:${DEST}/"
