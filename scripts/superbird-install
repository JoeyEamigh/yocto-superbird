#!/usr/bin/env bash
# Pull the most recent bridgething image from the OTA manifest and
# flash it to a Car Thing in burn mode. For fellow bridgething devs
# who don't want to build the image themselves - skips the multi-hour
# Yocto build and just grabs whatever was last uploaded via
# `just release`.
#
# Requires:
#   - flashthing-cli (cargo install flashthing-cli)
#   - curl, jq
#   - Car Thing in burn mode (USB enumerates as 1b8e:c003)
#
# After this finishes, run `just boot-kernel` to exit burn mode into
# the freshly flashed image.
#
# Env:
#   OTA_PUBLIC_BASE   manifest URL prefix (default
#                     https://ota.bridgething.com)

set -euo pipefail

variant="${1:-}"
case "$variant" in
  dev|prod) ;;
  *) echo "usage: $(basename "$0") dev|prod" >&2; exit 1 ;;
esac

OTA_PUBLIC_BASE="${OTA_PUBLIC_BASE:-https://ota.bridgething.com}"

flashthing="${FLASHTHING_CLI:-flashthing-cli}"
if ! command -v "$flashthing" >/dev/null 2>&1; then
  cat >&2 <<EOF
flashthing-cli not found on PATH.

Install with:
    cargo install flashthing-cli
    sudo flashthing-cli --setup    # udev rule for libusb burn-mode access (Linux)

Or set FLASHTHING_CLI=/path/to/binary.
EOF
  exit 2
fi

for tool in curl jq; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "$tool not on PATH" >&2
    exit 2
  fi
done

manifest_url="${OTA_PUBLIC_BASE}/manifest/${variant}"
echo "[install] fetching manifest: $manifest_url"
manifest="$(curl -fsSL "$manifest_url")"

zip_url="$(printf '%s' "$manifest" | jq -r '.flashthing_zip_url')"
zip_size="$(printf '%s' "$manifest" | jq -r '.flashthing_zip_size')"
version="$(printf '%s' "$manifest" | jq -r '.version')"

if [[ -z "$zip_url" || "$zip_url" == "null" ]]; then
  echo "[install] manifest missing flashthing_zip_url" >&2
  exit 1
fi

echo "[install] $variant version $version (~$((zip_size / 1024 / 1024)) MiB)"
dest="${TMPDIR:-/tmp}/bridgething-${variant}-image-superbird-flashthing.zip"
echo "[install] downloading $zip_url"
curl -fL --output "$dest" "$zip_url"

echo "[install] flashing $variant image (~30-60s)..."
"$flashthing" "$dest"

cat <<EOF

flash complete. exit burn mode into the new kernel with:
    just boot-kernel
EOF
