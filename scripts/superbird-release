#!/usr/bin/env bash
# Push bridgething images to Cloudflare R2 + publish a manifest the
# companion app polls for OTA. Replaces the previous gh-release flow.
#
# Run after a successful `just build`. Uploads `.swu`, `.zck`, and
# `.flashthing.zip` for the requested channel(s), then synthesizes
# `manifest/<channel>` JSON pointing at the uploaded artifacts.
#
# Usage:
#   superbird-release [channel]      # channel = dev | prod | all (default)
#
# Env:
#   R2_BUCKET            R2 bucket name (default: bridgething-ota)
#   OTA_PUBLIC_BASE      public URL prefix for the bucket
#                        (default: https://ota.bridgething.com)
#   WRANGLER             wrangler binary (default: wrangler)
#
# Requires `wrangler` authenticated against the Cloudflare account
# that owns the bucket.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DEPLOY="$REPO_ROOT/build/tmp/deploy/images/superbird"

R2_BUCKET="${R2_BUCKET:-bridgething-ota}"
OTA_PUBLIC_BASE="${OTA_PUBLIC_BASE:-https://ota.bridgething.com}"
WRANGLER="${WRANGLER:-wrangler}"

CHANNEL_ARG="${1:-all}"
case "$CHANNEL_ARG" in
  dev|prod|all) ;;
  *) echo "usage: $(basename "$0") [dev|prod|all]" >&2; exit 2 ;;
esac

if ! command -v "$WRANGLER" >/dev/null 2>&1; then
  echo "wrangler not on PATH (https://developers.cloudflare.com/workers/wrangler/install-and-update/)" >&2
  exit 2
fi
if ! command -v sha256sum >/dev/null 2>&1; then
  echo "sha256sum not on PATH" >&2
  exit 2
fi
if ! command -v jq >/dev/null 2>&1; then
  echo "jq not on PATH" >&2
  exit 2
fi

released_at="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
distro_version_file="$DEPLOY/.distro-version"
# DISTRO_VERSION+DATETIME is rendered into sw-description; we mirror
# it in the recipe by hashing the build's IMAGE_BUILD_ID. For now we
# stamp the version from the filesystem mtime of the .swu, formatted
# the same way (ISO + sortable). Producer can override via env.
version_from_artifact() {
  date -u -r "$1" +'%Y%m%d-%H%M%S'
}

upload_channel() {
  local channel="$1"
  local swu="$DEPLOY/bridgething-update-${channel}-superbird.swu"
  local zck="$DEPLOY/bridgething-${channel}-image-superbird.squashfs-lz4.zck"
  local zip="$DEPLOY/bridgething-${channel}-image-superbird-flashthing.zip"

  for f in "$swu" "$zck" "$zip"; do
    if [[ ! -e "$f" ]]; then
      echo "[release] missing $(basename "$f") for channel $channel; run 'just build' first" >&2
      exit 1
    fi
  done

  local version
  version="${SUPERBIRD_RELEASE_VERSION:-$(version_from_artifact "$swu")}"
  local prefix="releases/${channel}/${version}"
  local update_id swu_size zck_size zip_size

  update_id="$(sha256sum "$swu" | awk '{print $1}')"
  swu_size="$(stat -c %s "$swu")"
  zck_size="$(stat -c %s "$zck")"
  zip_size="$(stat -c %s "$zip")"

  echo "[release] channel=$channel version=$version update_id=${update_id:0:12}..."
  "$WRANGLER" r2 object put "$R2_BUCKET/${prefix}/$(basename "$swu")" --file "$swu"
  "$WRANGLER" r2 object put "$R2_BUCKET/${prefix}/$(basename "$zck")" --file "$zck"
  "$WRANGLER" r2 object put "$R2_BUCKET/${prefix}/$(basename "$zip")" --file "$zip"

  local manifest
  manifest="$(jq -n \
    --arg version "$version" \
    --arg channel "$channel" \
    --arg update_id "$update_id" \
    --arg swu_url "${OTA_PUBLIC_BASE}/${prefix}/$(basename "$swu")" \
    --arg zck_url "${OTA_PUBLIC_BASE}/${prefix}/$(basename "$zck")" \
    --arg zip_url "${OTA_PUBLIC_BASE}/${prefix}/$(basename "$zip")" \
    --argjson swu_size "$swu_size" \
    --argjson zck_size "$zck_size" \
    --argjson zip_size "$zip_size" \
    --arg released_at "$released_at" \
    --arg notes "${SUPERBIRD_RELEASE_NOTES:-Rolling latest bridgething ${channel} build.}" \
    '{
       version: $version,
       channel: $channel,
       update_id: $update_id,
       swu_url: $swu_url,
       swu_size: $swu_size,
       zck_url: $zck_url,
       zck_size: $zck_size,
       flashthing_zip_url: $zip_url,
       flashthing_zip_size: $zip_size,
       released_at: $released_at,
       notes: $notes
     }')"
  local manifest_tmp
  manifest_tmp="$(mktemp)"
  trap 'rm -f "$manifest_tmp"' RETURN
  printf '%s\n' "$manifest" > "$manifest_tmp"

  "$WRANGLER" r2 object put "$R2_BUCKET/manifest/${channel}" \
    --file "$manifest_tmp" \
    --content-type "application/json"
  echo "[release] published manifest/${channel} → ${OTA_PUBLIC_BASE}/manifest/${channel}"
}

if [[ "$CHANNEL_ARG" == "all" ]]; then
  upload_channel dev
  upload_channel prod
else
  upload_channel "$CHANNEL_ARG"
fi

echo "[release] done."
