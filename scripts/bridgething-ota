#!/usr/bin/env bash
# delta-ota a booted device. drives `host-gateway push-update` against the daemon.
#
# usage: bridgething-ota [--image dev|prod] [--swu PATH] [--zck PATH] [--url ws://...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEPLOY_DIR="$SCRIPT_DIR/../build/tmp/deploy/images/superbird"
BRIDGETHING_DIR="$SCRIPT_DIR/../../bridgething"

IMAGE=dev
SWU=""
ZCK=""
URL=""

usage() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
    exit 2
}

while [ $# -gt 0 ]; do
    case "$1" in
        --image)      IMAGE="$2"; shift 2 ;;
        --swu)        SWU="$2"; shift 2 ;;
        --zck)        ZCK="$2"; shift 2 ;;
        --url)        URL="$2"; shift 2 ;;
        -h|--help)    usage ;;
        *)            echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

case "$IMAGE" in
    dev|prod) ;;
    *) echo "[ota] --image must be 'dev' or 'prod', got: $IMAGE" >&2; exit 2 ;;
esac

: "${SWU:=$DEPLOY_DIR/bridgething-update-${IMAGE}-superbird.swu}"
: "${ZCK:=$DEPLOY_DIR/bridgething-${IMAGE}-image-superbird.squashfs-lz4.zck}"

[ -f "$SWU" ] || { echo "[ota] swu not found: $SWU" >&2; exit 1; }
[ -f "$ZCK" ] || { echo "[ota] zck not found: $ZCK" >&2; exit 1; }

HOST="${SUPERBIRD_HOST:-bridgething.local}"
: "${URL:=ws://${HOST}:8892/}"

echo "[ota] swu  = $(basename "$SWU") ($(du -h "$SWU" | cut -f1))"
echo "[ota] zck  = $(basename "$ZCK") ($(du -h "$ZCK" | cut -f1))"
echo "[ota] url  = $URL"

cargo run --quiet --manifest-path "$BRIDGETHING_DIR/Cargo.toml" -p bridgething-host-gateway -- \
    --url "$URL" \
    push-update \
    --zck "$ZCK" \
    "$SWU"

echo "[ota] done."
