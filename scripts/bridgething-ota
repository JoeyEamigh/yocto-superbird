#!/usr/bin/env bash
# bridgething-ota - delta-OTA iteration helper.
#
# Stands up superbird-delta-stub.py on the host side of the USB-gadget
# link, scp's the .swu manifest to the device, then runs
# `bridgething-ab apply` over SSH. swupdate writes the inactive slot
# and the in-manifest bootenv block atomically flips active_slot;
# bridgething-ab follows up with want_boot=kernel + the new slot's
# try counter. Then we reboot. ~one-shot equivalent of a full flash
# but skipping the burn-mode dance.
#
# The .swu's sw-description hardcodes the URL
# `http://10.42.1.1:8000/system.img.zck` (rendered from
# SUPERBIRD_OTA_DELTA_URL_BASE at build time). This script stages a
# tmp dir with that filename symlinked to the real .zck artifact so
# the URL resolves. Override --port if you've moved the bbvar.
#
# Defaults target bridgething-update-dev's artifacts (dev image, with
# the dev packagegroup + persistent /opt overlay). Pass --image prod
# (or explicit --swu / --zck) to push the prod image instead.
#
# Usage:
#   bridgething-ota [--image dev|prod] [--swu PATH] [--zck PATH]
#                   [--port PORT] [--no-reboot] [--no-server]
#
# Env:
#   SUPERBIRD_HOST   device IP (default 10.42.1.2)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEPLOY_DIR="$SCRIPT_DIR/../build/tmp/deploy/images/superbird"

IMAGE=dev
SWU=""
ZCK=""
PORT=8000
DO_REBOOT=1
WITH_SERVER=1

usage() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
    exit 2
}

while [ $# -gt 0 ]; do
    case "$1" in
        --image)      IMAGE="$2"; shift 2 ;;
        --swu)        SWU="$2"; shift 2 ;;
        --zck)        ZCK="$2"; shift 2 ;;
        --port)       PORT="$2"; shift 2 ;;
        --no-reboot)  DO_REBOOT=0; shift ;;
        --no-server)  WITH_SERVER=0; shift ;;
        -h|--help)    usage ;;
        *)            echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

case "$IMAGE" in
    dev|prod) ;;
    *) echo "[ota] --image must be 'dev' or 'prod', got: $IMAGE" >&2; exit 2 ;;
esac

: "${SWU:=$DEPLOY_DIR/bridgething-update-${IMAGE}-superbird.swu}"
: "${ZCK:=$DEPLOY_DIR/bridgething-${IMAGE}-image-superbird.squashfs-zst.zck}"

[ -f "$SWU" ] || { echo "[ota] swu not found: $SWU" >&2; exit 1; }

HOST="${SUPERBIRD_HOST:-10.42.1.2}"
SSH_OPTS=(-o UserKnownHostsFile=/dev/null -o StrictHostKeyChecking=no -o LogLevel=ERROR)
ssh_dev() { ssh "${SSH_OPTS[@]}" "root@${HOST}" "$@"; }

SERVE_DIR=""
SERVER_PID=""
cleanup() {
    if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" 2>/dev/null; then
        kill "$SERVER_PID" 2>/dev/null || true
        wait "$SERVER_PID" 2>/dev/null || true
    fi
    if [ -n "$SERVE_DIR" ] && [ -d "$SERVE_DIR" ]; then
        rm -rf "$SERVE_DIR"
    fi
}
trap cleanup EXIT

if [ "$WITH_SERVER" = "1" ]; then
    [ -f "$ZCK" ] || { echo "[ota] zck not found: $ZCK" >&2; exit 1; }
    SERVE_DIR=$(mktemp -d -t bridgething-ota.XXXXXX)
    ln -s "$(realpath "$ZCK")" "$SERVE_DIR/system.img.zck"

    echo "[ota] serving $(basename "$ZCK") as system.img.zck on 10.42.1.1:$PORT"
    "$SCRIPT_DIR/superbird-delta-stub.py" "$SERVE_DIR" --port "$PORT" &
    SERVER_PID=$!

    # ThreadingHTTPServer binds in the constructor before serve_forever
    # so the socket is listening as soon as the python process is alive.
    # If bind fails (address in use, 10.42.1.1 not assigned) the
    # process exits within milliseconds - check that here.
    sleep 0.5
    if ! kill -0 "$SERVER_PID" 2>/dev/null; then
        echo "[ota] delta stub failed to start - is the USB-gadget link up?" >&2
        exit 1
    fi
fi

REMOTE_SWU="/tmp/$(basename "$SWU")"
echo "[ota] uploading $(basename "$SWU") ($(du -h "$SWU" | cut -f1)) to ${HOST}:${REMOTE_SWU}"
scp -C "${SSH_OPTS[@]}" -q "$SWU" "root@${HOST}:${REMOTE_SWU}"

echo "[ota] applying"
ssh_dev "bridgething-ab apply $REMOTE_SWU"

if [ "$DO_REBOOT" = "1" ]; then
    echo "[ota] rebooting"
    # systemctl reboot drops the SSH session, so tolerate non-zero exit.
    ssh_dev "systemctl reboot" || true
fi

echo "[ota] done."
