#!/usr/bin/env bash
# Open an SSH tunnel from this host's port 9223 to the device's
# chromium CDP port 9223.
#
# Why a tunnel instead of direct LAN access: chromium ≥ M111 silently
# ignores --remote-debugging-address=<non-localhost>. The browser
# always binds 127.0.0.1, even when the flag asks for 0.0.0.0. Google
# removed the bind-elsewhere path for security reasons (CVE class).
# The Car Thing's only interface is the USB-CDC-ECM gadget so there
# is no real LAN exposure to worry about, but chromium doesn't care —
# it still refuses. SSH tunneling is the canonical workaround.
#
# Why the same port on both sides: chromium hardcodes its bind port
# into every webSocketDebuggerUrl it announces in /json/version and
# /json/list. chrome://inspect on the dev host parses those URLs and
# opens the DevTools session against the announced ws://127.0.0.1:<p>
# directly. If the host tunnel uses a different port number, the
# announced URL points at a port that isn't tunneled (or at a desktop
# chromium that happens to occupy that port) and chrome://inspect
# loops on "Device information is stale". Matching ports on both
# sides keeps the announced URL reachable as-is. We use 9223 instead
# of chromium's traditional 9222 because a desktop chromium with its
# own --remote-debugging-port=9222 will collide on the host side.
#
# Once this script is running, point a host browser at:
#   chrome://inspect              -> add discovery target localhost:9223
#   curl http://localhost:9223/json/version
#
# Press Ctrl-C to close the tunnel.

set -euo pipefail

PORT="${1:-9223}"
HOST="${SUPERBIRD_HOST:-bridgething.local}"

# -N: no remote command (just forward)
# -T: no pseudo-tty
# -o ServerAliveInterval=10: keep idle USB-CDC link alive
exec ssh \
    -L "${PORT}:127.0.0.1:9223" \
    -N -T \
    -o ServerAliveInterval=10 \
    -o UserKnownHostsFile=/dev/null \
    -o StrictHostKeyChecking=no \
    -o LogLevel=ERROR \
    "root@${HOST}"
