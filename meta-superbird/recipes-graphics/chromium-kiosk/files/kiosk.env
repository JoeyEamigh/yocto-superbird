# /etc/default/chromium-kiosk - runtime overrides for the kiosk launcher.
# Restart with `systemctl restart chromium-kiosk` to apply.
#
# Baked from the distro knobs at build time:
#   CHROMIUM_KIOSK_URL          -> KIOSK_URL
#   CHROMIUM_KIOSK_PROXY_SERVER -> KIOSK_PROXY_SERVER
#
# Override here without rebuilding:
#   KIOSK_URL=http://your-url
#   KIOSK_PROXY_SERVER=socks5://127.0.0.1:1080
#   KIOSK_EXTRA=--enable-logging=stderr --v=1
#   KIOSK_SINGLE_PROCESS=0
KIOSK_URL=@@KIOSK_URL@@
KIOSK_PROXY_SERVER=@@KIOSK_PROXY_SERVER@@
