# Friendly aliases for the MBR-on-bootloader scheme. The bbclass's
# write-mbr.py overlays these 4 entries onto sector 0 of
# bootloader.dump pointing at the same byte offsets as the AML MPT
# partitions. Mainline reads the MBR; u-boot uses AML names.
#
# Only the Linux-visible partitions get aliases. boot_a/b, fip_a/b,
# logo, env, dtbo_a/b, misc, bootloader live in the AML MPT only
# (we max out MBR's 4 primary slots on system_a/b + settings + data).
# Userspace that needs to touch misc (e.g. bridgething's AB module
# reading the BCB) seeks into /dev/mmcblk0 directly at offset
# 0x51e16800.

KERNEL=="mmcblk0p1", SYMLINK+="system_a"
KERNEL=="mmcblk0p2", SYMLINK+="system_b"
KERNEL=="mmcblk0p3", SYMLINK+="settings"
KERNEL=="mmcblk0p4", SYMLINK+="data"
