# Bridgething mainline-u-boot mount layout (milestone 1: bsp).
#
# Root is squashfs (read-only), selected by the kernel root=PARTLABEL=root_a
# cmdline - no fstab row needed for /. /var lives on the `data` partition,
# which superbird-provision creates in the free eMMC space on first boot
# (the flashed wic only carries env + boot_a + root_a). x-systemd.makefs
# formats `data` ext4 the first time it is seen blank. /mnt/uboot-env
# exposes the u-boot environment partition for fw_printenv / fw_setenv.

PARTLABEL=data  /var            ext4  rw,noatime,nofail,x-systemd.makefs  0 2
PARTLABEL=env   /mnt/uboot-env  vfat  rw,noatime,nofail                   0 2

proc            /proc       proc    defaults                    0 0
sysfs           /sys        sysfs   defaults                    0 0
devpts          /dev/pts    devpts  gid=4,mode=620,ptmxmode=000 0 0
tmpfs           /dev/shm    tmpfs   defaults                    0 0
tmpfs           /tmp        tmpfs   defaults                    0 0
tmpfs           /run        tmpfs   defaults                    0 0
