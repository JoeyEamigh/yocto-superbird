# Bridgething mainline-u-boot mount layout (milestone 1: bsp).
#
# Root is squashfs (read-only), selected by the kernel
# root=PARTLABEL=root_a cmdline - no fstab row needed for /.
# /mnt/uboot-env exposes the u-boot environment partition for
# fw_printenv / fw_setenv.

PARTLABEL=env   /mnt/uboot-env  vfat  rw,noatime,nofail                   0 2

proc            /proc       proc    defaults                    0 0
sysfs           /sys        sysfs   defaults                    0 0
devpts          /dev/pts    devpts  gid=4,mode=620,ptmxmode=000 0 0
tmpfs           /dev/shm    tmpfs   defaults                    0 0
tmpfs           /tmp        tmpfs   defaults                    0 0
tmpfs           /run        tmpfs   defaults                    0 0
